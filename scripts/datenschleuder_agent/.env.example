# Redis Configuration (Cockpit Redis server)
REDIS_HOST=datenschleuder.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# set loglevel
LOGLEVEL=DEBUG

# Agent Identity (auto-detected if not set)
# AGENT_HOSTNAME=app-prod-01

# Git Configuration — repositories are now defined in repos.yaml (not GIT_REPO_PATH)
# See repos.yaml for the format: each entry maps a named ID to a path and container name.

# Docker Configuration — containers are now defined in containers.yaml
# NIFI_CONTAINERS and ZOOKEEPER_CONTAINER env vars are no longer used.
# See containers.yaml for the format: each entry maps a named ID to a container name and type.

# Operational Settings
HEARTBEAT_INTERVAL=30
COMMAND_TIMEOUT=30
DOCKER_TIMEOUT=60
