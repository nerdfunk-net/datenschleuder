# Redis Configuration (Cockpit Redis server)
REDIS_HOST=datenschleuder.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# MODE=docker or MODE=bare (default: docker)
MODE=bare

# set loglevel
LOGLEVEL=DEBUG

# Agent Identity (auto-detected from hostname if not set)
# AGENT_ID=app-prod-01

# Operational Settings
HEARTBEAT_INTERVAL=30
COMMAND_TIMEOUT=30
DOCKER_TIMEOUT=60
