# Redis Configuration (Cockpit Redis server)
REDIS_HOST=datenschleuder.example.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# set loglevel
LOGLEVEL=DEBUG

# Agent Identity (auto-detected if not set)
# AGENT_HOSTNAME=app-prod-01

# Git Configuration (comma-separated list for multiple repositories)
GIT_REPO_PATH=/opt/app/config,/opt/grafana/config,/opt/monitoring/config

# NiFi Configuration (comma-separated list for multiple NiFi containers)
NIFI_CONTAINERS=nifi-nifi-docker-1-1,nifi-nifi-docker-2-1,nifi-nifi-docker-3-1

# ZooKeeper Configuration (comma-separated list; optional, may run on a different host)
# ZOOKEEPER_CONTAINER=nifi-zookeeper-1-1,nifi-zookeeper-2-1,nifi-zookeeper-3-1

# Operational Settings
HEARTBEAT_INTERVAL=30
COMMAND_TIMEOUT=30
DOCKER_TIMEOUT=60
